NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://clinic:clinic_secret@localhost:5432/clinic_saas?schema=public
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_SECRET_KEY=change-me-admin-registration-secret
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=10
LOGIN_LOCKOUT_MS=3600000
